{
  "expo": {
    "name": "Hijra",
    "slug": "hijra",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hijra",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.doukouss.hijra"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.doukouss.hijra"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Oldenburg/Oldenburg-Regular.ttf",
            "./assets/fonts/Oleo_Script/OleoScript-Bold.ttf",
            "./assets/fonts/Oleo_Script/OleoScript-Regular.ttf",
            "./assets/fonts/Open_Sans/OpenSans-Bold.ttf",
            "./assets/fonts/Open_Sans/OpenSans-Light.ttf",
            "./assets/fonts/Open_Sans/OpenSans-Medium.ttf",
            "./assets/fonts/Open_Sans/OpenSans-Regular.ttf",
            "./assets/fonts/Open_Sans/OpenSans-SemiBold.ttf"
          ]
        }
      ],
      [
        "expo-asset",
        {
          "assets": ["./assets/images/home_background.png"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "73adef44-9df7-4d72-88a9-63ce67607add"
      }
    },
    "owner": "doukouss"
  }
}
